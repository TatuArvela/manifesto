# When set, the client switches from local-only mode to server-backed mode:
# users must log in, notes sync via the Manifesto server. Leave unset to keep
# the default offline-first behaviour using localStorage.
#
# VITE_MANIFESTO_SERVER=http://localhost:3001

# Override the link-preview metadata API used by the editor when the user
# pastes a URL. Defaults to microlink.io. Self-host or proxy if you don't
# want pasted URLs to leave your network.
#
# VITE_LINK_PREVIEW_API=https://api.microlink.io
