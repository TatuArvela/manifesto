# Manifesto server configuration. Copy to `.env` and adjust per deployment.

# HTTP listen port. Default 3001.
# PORT=3001

# Storage driver. Either `sqlite` (single file, zero-config) or `postgres`
# (managed database, scale-out). Default `sqlite`.
# STORAGE_DRIVER=sqlite

# Postgres connection string — required and read only when STORAGE_DRIVER=postgres.
# DATABASE_URL=postgres://user:password@host:5432/manifesto

# Authentication provider. Either `local` (username + argon2 password) or
# `oidc` (Authorization Code Flow with PKCE against any OpenID Connect IdP —
# Authentik, Keycloak, Google, GitHub Enterprise, Auth0, Okta, etc.).
# Default `local`.
# AUTH_PROVIDER=local

# OIDC settings — required and read only when AUTH_PROVIDER=oidc. The server
# fails fast at boot if any of the required values are missing.
#
# OIDC_ISSUER=https://idp.example.com
# OIDC_CLIENT_ID=manifesto
# OIDC_CLIENT_SECRET=...
# OIDC_REDIRECT_URI=https://server.example.com/api/auth/callback
# OIDC_POST_LOGIN_REDIRECT=https://notes.example.com/auth-callback
# OIDC_SCOPES=openid,profile,email

# Directory for the SQLite database (and any future blob storage). The
# server will create it if it does not exist. Defaults to `./data`.
# DATA_DIR=./data

# Optional override for the SQLite database path. Defaults to
# `${DATA_DIR}/manifesto.db`.
# MANIFESTO_DB=./data/manifesto.db

# Comma-separated list of origins permitted by the CORS layer. Default is
# the Vite dev server (`http://localhost:5173`). Add the production client
# origin here when you deploy.
# CORS_ORIGINS=http://localhost:5173,https://notes.example.com

# Session lifetime in days. Sessions are bumped forward on each
# authenticated request, so this is the inactivity timeout. Default 30.
# SESSION_TTL_DAYS=30

# Argon2id parameters. The defaults are OWASP-recommended for an
# interactive auth flow on modest hardware. Increase memory or time cost
# on stronger machines for stronger hashing.
# ARGON2_MEMORY_KIB=19456
# ARGON2_TIME_COST=2
# ARGON2_PARALLELISM=1

# Logger threshold. One of: debug | info | warn | error. Default `info`.
# LOG_LEVEL=info
