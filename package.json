{
  "name": "manifesto",
  "private": true,
  "license": "MIT",
  "author": "Tatu Arvela",
  "repository": {
    "type": "git",
    "url": "https://github.com/TatuArvela/manifesto.git"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@biomejs/biome": "^2.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["argon2", "better-sqlite3", "esbuild"]
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @manifesto/shared build && pnpm -r test"
  }
}
